# Copy this file to scripts/.env and fill in the values.
# Never commit .env to git.

# Supabase — Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase — Settings > API > anon public key
# Used by the Netlify edge function to read/write the profiles row.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — Settings > API > service_role key (NOT the anon key)
# The service-role key bypasses RLS, which is required for bulk inserts.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your live Netlify site's profile API (the Netlify Blobs source)
NETLIFY_PROFILES_URL=https://your-site.netlify.app/api/profiles
